      },
      "source": [
        "---\n",
        "## ภารกิจที่ 2: ปลุกชีพเสียง (Signal Generation)\n",
        "เมื่อเรามีเวลาแล้ว ต่อไปเราจะสร้าง \"คลื่น\" (Wave) ขึ้นมาเกาะบนแกนเวลานั้น\n",
        "สมการทางคณิตศาสตร์ของคลื่นเสียง (Sine Wave) พื้นฐานคือ:\n",
        "$$y(t) = A \\cdot \\sin(2 \\cdot \\pi \\cdot f \\cdot t)$$\n",
        "\n",
        "* $A$ = แอมพลิจูด (ความดัง)\n",
        "* $f$ = ความถี่ (ระดับเสียงแหลม/ทุ้ม หน่วยเป็น Hz)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 25,
      "metadata": {
        "id": "mission2-code",
        "outputId": "b483be24-3f2f-47bc-f83d-3048eef43324",
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 410
        }
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1000x400 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ],
      "source": [
        "f = 440.0   # ความถี่ 440 Hz (เสียงโน้ต A4 หรือเสียงตั้งสายกีตาร์)\n",
        "A = 1.0     # แอมพลิจูดสูงสุด (ความดัง)\n",
        "\n",
        "# MISSION 2: แปลงสมการคณิตศาสตร์ด้านบนให้เป็นโค้ด Python\n",
        "# Hint: ค่า pi ใช้ np.pi และฟังก์ชัน sin ใช้ np.sin()\n",
        "y =  A* np.sin(2*np.pi*f*t)\n",
        "\n",
        "# มาดูกราฟหน้าตาคลื่นที่เราสร้างขึ้น (พล็อตแค่ 0.01 วินาทีแรกให้เห็นคลื่นชัดๆ)\n",
        "plt.figure(figsize=(10, 4))\n",
        "plt.plot(t[:441], y[:441], color='blue') # 441 จุด = 0.01 วินาที\n",
        "plt.title(\"My First Sine Wave (440 Hz)\")\n",
        "plt.xlabel(\"Time (Seconds)\")\n",
        "plt.ylabel(\"Amplitude\")\n",
        "plt.grid(True)\n",
        "plt.show()"
      ]
    },
